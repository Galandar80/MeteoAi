{
  "rewrites": [
    {
      "source": "/meteo/:country/:region/:place",
      "destination": "/api/meteo-page?country=:country&region=:region&place=:place"
    }
  ],
  "headers": [
    {
      "source": "/meteo/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
